// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  ownerId         String
  owner           User     @relation("OrgOwner", fields: [ownerId], references: [id])
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  status          String   @default("active")
  isPlatform      Boolean  @default(false)
  disabledScreens String?  @db.Text
  contactEmail    String?
  gstVatNumber    String?
  address         String?
  fiscalYear      String?  @default("jan-dec")
  currency        String?  @default("USD")
  timeZone        String?  @default("UTC-5")
  logoUrl         String?
  maxUsers        Int      @default(5)
  createdAt       DateTime @default(now())

  users          User[]          @relation("OrgUsers")
  roles          Role[]
  customers      Customer[]
  suppliers      Supplier[]
  invoices       Invoice[]
  expenses       Expense[]
  products       Product[]
  stockMovements StockMovement[]
  warehouses     Warehouse[]
  purchaseBills  PurchaseBill[]
  bankAccounts   BankAccount[]
  notifications  Notification[]
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  isSystemRole   Boolean  @default(false)
  createdAt      DateTime @default(now())

  users           User[]
  rolePermissions RolePermission[]

  @@unique([organizationId, name])
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  role         Role   @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model User {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation("OrgUsers", fields: [organizationId], references: [id])
  roleId             String?
  role               Role?    @relation(fields: [roleId], references: [id])
  ownedOrgs          Organization[] @relation("OrgOwner")

  email              String
  password           String
  name               String?
  emailVerified      Boolean  @default(false)
  twoFactorEnabled   Boolean  @default(false)
  twoFactorSecret    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]
  screenBlocks            UserScreenBlock[]

  @@unique([organizationId, email])
  @@index([roleId])
}

model UserScreenBlock {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenKey String
  createdAt DateTime @default(now())

  @@unique([userId, screenKey])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// --- Dashboard Domain Models ---

model Customer {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  phone          String?
  address        String?
  creditLimit    Decimal   @default(0.00) @db.Decimal(12, 2)
  status         String    @default("Active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]

  @@unique([organizationId, email])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoiceNo      String
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  amount         Decimal       @db.Decimal(12, 2)
  status         String        @default("pending")
  issuedAt       DateTime      @default(now())
  dueAt          DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, invoiceNo])
  @@index([organizationId, status, paidAt])
}

model Expense {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  category       String
  description    String?
  amount         Decimal  @db.Decimal(12, 2)
  date           DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, date])
}

model Product {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  name              String
  sku               String
  barcode           String?
  category          String?
  unit              String   @default("Unit")
  imageUrl          String?
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(10)
  purchasePrice     Decimal  @default(0.00) @db.Decimal(10, 2)
  sellingPrice      Decimal  @db.Decimal(10, 2)
  taxRate           Decimal  @default(0.00) @db.Decimal(5, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stockMovements    StockMovement[]

  @@unique([organizationId, sku])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  category       String?
  contactEmail   String?
  phone          String?
  paymentTerms   String   @default("Net 30")
  status         String   @default("Active")
  dueAmount      Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       SupplierPayment[]
  purchaseBills  PurchaseBill[]

  @@unique([organizationId, name])
}

model PurchaseBill {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  billNo         String
  amount         Decimal  @db.Decimal(12, 2)
  paidAmount     Decimal  @default(0.00) @db.Decimal(12, 2)
  status         String   @default("Unpaid")
  dueDate        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, billNo])
}

model SupplierPayment {
  id             String   @id @default(cuid())
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime @default(now())
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  code           String?
  address        String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockMovements StockMovement[]

  @@unique([organizationId, name])
}

model StockMovement {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String   // 'Stock In', 'Stock Out', 'Transfer', 'Damaged', 'Adjustment'
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku            String
  itemName       String
  quantity       Int
  warehouse      String   @default("Main Warehouse")
  warehouseId    String?
  warehouseRef   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  status         String   @default("Completed")
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
}

model BankAccount {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  accountNumber  String   @unique
  bankName       String
  balance        Decimal  @db.Decimal(14, 2) @default(0)
  currency       String   @default("USD")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, isActive])
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  message        String
  type           String   @default("info")
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  organizations Organization[]
  features      PlanFeature[]
}

model PlanFeature {
  id         String   @id @default(cuid())
  planId     String
  plan       SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey String
  createdAt  DateTime @default(now())

  @@unique([planId, featureKey])
}


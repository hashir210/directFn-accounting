# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MySQL via Docker)
# Start MySQL with: docker compose up -d
# Container: finflow_mysql | Host port: 3307 → Container port: 3306 | DB: finflow
DATABASE_URL="mysql://root:password@127.0.0.1:3307/finflow"

# JWT Secrets
JWT_ACCESS_SECRET="your_jwt_access_secret_key_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_here"

# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Nodemailer / SMTP (Email notifications)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SMTP_FROM="noreply@finflow.com"

# Client URL (Frontend)
CLIENT_URL="http://localhost:3000"
